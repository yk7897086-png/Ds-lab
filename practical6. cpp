//Linear queue

#include <iostream>
using namespace std;

#define MAX 5
int queue[MAX], front = -1, rear = -1;

void insert(int x) {
    if (rear == MAX - 1)
        cout << "Overflow\n";
    else {
        if (front == -1) front = 0;
        queue[++rear] = x;
    }
}

void del() {
    if (front == -1)
        cout << "Underflow\n";
    else {
        cout << "Deleted: " << queue[front] << endl;
        if (front == rear)
            front = rear = -1;
        else
            front++;
    }
}

void display() {
    if (front == -1)
        cout << "Queue empty\n";
    else {
        for (int i = front; i <= rear; i++)
            cout << queue[i] << " ";
        cout << endl;
    }
}

int main() {
    insert(10); insert(20); insert(30);
    display();
    del();
    display();
}

//circular queue

#include <iostream>
using namespace std;

#define SIZE 5
int cq[SIZE], front = -1, rear = -1;

void insert(int x) {
    if ((rear + 1) % SIZE == front)
        cout << "Overflow\n";
    else {
        if (front == -1)
            front = rear = 0;
        else
            rear = (rear + 1) % SIZE;
        cq[rear] = x;
    }
}

void del() {
    if (front == -1)
        cout << "Underflow\n";
    else {
        cout << "Deleted: " << cq[front] << endl;
        if (front == rear)
            front = rear = -1;
        else
            front = (front + 1) % SIZE;
    }
}

void display() {
    if (front == -1)
        cout << "Empty\n";
    else {
        int i = front;
        while (true) {
            cout << cq[i] << " ";
            if (i == rear) break;
            i = (i + 1) % SIZE;
        }
        cout << endl;
    }
}

int main() {
    insert(1); insert(2); insert(3);
    display();
    del();
    display();
}

//priority queue

#include <iostream>
using namespace std;

#define SIZE 5

struct item {
    int value, priority;
};

item pq[SIZE];
int count = 0;

void insert(int val, int pr) {
    if (count == SIZE)
        cout << "Overflow\n";
    else {
        int i = count - 1;
        while (i >= 0 && pq[i].priority < pr) {
            pq[i + 1] = pq[i];
            i--;
        }
        pq[i + 1].value = val;
        pq[i + 1].priority = pr;
        count++;
    }
}

void del() {
    if (count == 0)
        cout << "Underflow\n";
    else {
        cout << "Deleted: " << pq[0].value << endl;
        for (int i = 1; i < count; i++)
            pq[i - 1] = pq[i];
        count--;
    }
}

void display() {
    for (int i = 0; i < count; i++)
        cout << pq[i].value << "(" << pq[i].priority << ") ";
    cout << endl;
}

int main() {
    insert(10, 2);
    insert(20, 5);
    insert(15, 3);

    display();
    del();
    display();
}